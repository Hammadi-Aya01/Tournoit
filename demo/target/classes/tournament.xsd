<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="http://esport.tournament.com"
           xmlns:tns="http://esport.tournament.com"
           elementFormDefault="qualified">

    <!-- Définition d'un Joueur -->
    <xs:complexType name="Player">
        <xs:sequence>
            <xs:element name="id" type="xs:int"/>
            <xs:element name="pseudo" type="xs:string"/>
            <xs:element name="email" type="xs:string"/>
            <xs:element name="rank" type="xs:string"/>
            <xs:element name="score" type="xs:int" default="0"/>
        </xs:sequence>
    </xs:complexType>

    <!-- Définition d'une Équipe -->
    <xs:complexType name="Team">
        <xs:sequence>
            <xs:element name="id" type="xs:int"/>
            <xs:element name="name" type="xs:string"/>
            <xs:element name="players" type="tns:Player" minOccurs="1" maxOccurs="5"/>
            <xs:element name="wins" type="xs:int" default="0"/>
            <xs:element name="losses" type="xs:int" default="0"/>
        </xs:sequence>
    </xs:complexType>

    <!-- Définition d'un Match -->
    <xs:complexType name="Match">
        <xs:sequence>
            <xs:element name="id" type="xs:int"/>
            <xs:element name="team1Id" type="xs:int"/>
            <xs:element name="team2Id" type="xs:int"/>
            <xs:element name="scoreTeam1" type="xs:int"/>
            <xs:element name="scoreTeam2" type="xs:int"/>
            <xs:element name="date" type="xs:dateTime"/>
            <xs:element name="status" type="tns:MatchStatus"/>
        </xs:sequence>
    </xs:complexType>

    <!-- Énumération des statuts -->
    <xs:simpleType name="MatchStatus">
        <xs:restriction base="xs:string">
            <xs:enumeration value="SCHEDULED"/>
            <xs:enumeration value="IN_PROGRESS"/>
            <xs:enumeration value="COMPLETED"/>
            <xs:enumeration value="CANCELLED"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- Élément racine du tournoi -->
    <xs:element name="Tournament">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="name" type="xs:string"/>
                <xs:element name="game" type="xs:string"/>
                <xs:element name="startDate" type="xs:date"/>
                <xs:element name="teams" type="tns:Team" minOccurs="2" maxOccurs="unbounded"/>
                <xs:element name="matches" type="tns:Match" minOccurs="0" maxOccurs="unbounded"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

</xs:schema>